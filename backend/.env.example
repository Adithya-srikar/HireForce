# ─── Database ────────────────────────────────────────────────
DB_URL=mongodb://localhost:27017/
DB_NAME=hireforce

# ─── Google Gemini ────────────────────────────────────────────
GOOGLE_API_KEY=your_google_gemini_api_key_here

# ─── External profile data ────────────────────────────────────
GITHUB_TOKEN=your_github_personal_access_token_here
APIFY_TOKEN=your_apify_api_token_here

# ─── GitHub OAuth (for /student/github/connect flow) ─────────
GITHUB_CLIENT_ID=your_github_oauth_app_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_app_client_secret
# The callback URL you registered in your GitHub OAuth App settings:
GITHUB_REDIRECT_URI=http://localhost:8000/student/github/callback

# ─── Auth / JWT ───────────────────────────────────────────────
# Generate a strong random string, e.g.: openssl rand -hex 32
JWT_SECRET=your_super_secret_jwt_key_here
JWT_ALGORITHM=HS256
# Token expiry in minutes (default 10080 = 7 days)
JWT_EXPIRE_MINUTES=10080

# ─── Email (SMTP) ─────────────────────────────────────────────
# Leave blank to use console stub (emails are logged, not sent)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here
EMAIL_FROM=HireForce <your_email@gmail.com>

# ─── App ──────────────────────────────────────────────────────
ENVIRONMENT=development
APP_BASE_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173
